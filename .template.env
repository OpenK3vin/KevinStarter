# Feature flag env vars — prefix all flags with VITE_FF_
# Example: VITE_FF_MY_FLAG=false

VITE_FF_EXAMPLE=false

# PostgreSQL database URL
DATABASE_URL=postgres://user:password@localhost:5432/db

# better-auth — generate a strong random secret for production
BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=e
