## Pathname and Params

### usePathname

```typescript
'use client';

import { usePathname } from 'next/navigation';

export function Navigation() {
  const pathname = usePathname(); // e.g., /posts/123

  return (
    <nav>
      <Link
        href="/posts"
        className={pathname === '/posts' ? 'active' : ''}
      >
        Posts
      </Link>
    </nav>
