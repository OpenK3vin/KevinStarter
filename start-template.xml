  if (dir === 'asc') return <IconChevronUp size={12} className="ml-1 opacity-70" />
  if (dir === 'desc') return <IconChevronDown size={12} className="ml-1 opacity-70" />
  return <IconSelector size={12} className="ml-1 opacity-40" />
}

